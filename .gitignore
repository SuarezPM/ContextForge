# --- Project-specific -----------------------------------------------------
# Benchmark output (regenerated each run); keep logs/ for the audit trail
demo/benchmark_v5_results.json
logs/*.log

# Paper LaTeX intermediate files (the .pdf is committed)
paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.toc

# tectonic cache
.tectonic-cache/

# uv lock not in use; pin requirements via pyproject.toml only

# --- V7 observability runtime data ---------------------------------------
# JSONL audit log dir auto-created by apohara_context_forge.observability
# at runtime / during tests. Production deployments should mount this to
# persistent storage; the in-repo path is transient.
.apohara/

# --- AI agent tooling (dev-machine-specific, NOT for public repo) --------
# These dirs are configuration for AI coding assistants (Claude Code,
# Codex CLI, ecc-tools bot, etc.) that the maintainers use locally.
# They have zero value to repo cloners and may leak local preferences.
.agents/
.claude/
.codex/
.cursor/
.aider*
.continue/

# --- Internal planning + release prep (mirrored to ~/Documentos/Apohara_PRIVATE/) ---
# Maintainer planning docs, submission drafts, tag annotations live
# outside the public repo to keep the surface professional.
.omc/
.release/

# --- VS Code workspace files ---
*.code-workspace

# Maintainer-only private notes (NEVER commit)
CLAUDE.local.md
CLAUDE.local.*
